# ============================================================
# ENVIRONMENT VARIABLES — copy this file to .env.local
# ============================================================
# NEXT_PUBLIC_ prefix means the variable is available in the
# browser (client-side). Without this prefix it would only be
# available on the server.
#
# Back-end team: replace the URL below with your actual API URL.
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:8000/api
